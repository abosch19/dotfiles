#!/usr/bin/env bash

set -euo pipefail

##? Setups the environment
#?? 1.0.0
##?
##? Usage:
##?    install

echo "🚀 Welcome to the abosch19/dotfiles installer!"
echo "-------------------------------------------------"
echo
export DOTFILES_PATH="$HOME/.dotfiles"

# To test that git is installed (if not macOS will prompt an installer)
git --version

# Pick a shell to run the install script with: prefer zsh, fall back to bash.
if command -v zsh &> /dev/null; then
  RUNNER="zsh"
elif command -v bash &> /dev/null; then
  RUNNER="bash"
  echo "ℹ️  ZSH not found — using bash. Aliases work the same in both."
else
  echo "🚨 Neither zsh nor bash is installed. Install one and run this again:"
  echo
  if [[ "${OSTYPE:-}" == darwin* ]]; then
    echo "  • macOS (Homebrew):   brew install zsh"
  elif command -v apt &> /dev/null; then
    echo "  • Debian/Ubuntu:      sudo apt update && sudo apt install -y zsh"
  elif command -v dnf &> /dev/null; then
    echo "  • Fedora/RHEL:        sudo dnf install -y zsh"
  elif command -v pacman &> /dev/null; then
    echo "  • Arch:               sudo pacman -S zsh"
  elif command -v zypper &> /dev/null; then
    echo "  • openSUSE:           sudo zypper install zsh"
  elif command -v apk &> /dev/null; then
    echo "  • Alpine:             sudo apk add zsh"
  else
    echo "  • macOS (Homebrew):   brew install zsh"
    echo "  • Debian/Ubuntu:      sudo apt install zsh"
    echo "  • Fedora/RHEL:        sudo dnf install zsh"
    echo "  • Arch:               sudo pacman -S zsh"
  fi
  exit 1
fi

echo "👉  Cloning into: '$DOTFILES_PATH'"
git clone --depth 1 git@github.com:abosch19/dotfiles.git "$DOTFILES_PATH"

"$RUNNER" "$DOTFILES_PATH/scripts/install.sh"
